    <!-- Quiz Questions - EN 301 549 Accessibility Standards -->
    <!-- Question 1: True/False about keyboard interface -->
    <string name="quiz_question_1">Bei der Barrierefreiheitsprüfung von Android-Apps gemäß EN 301 549 muss jede Funktionalität über eine Tastaturschnittstelle bedienbar sein.</string>
    
    <!-- Question 2: True/False about text alternatives for images -->
    <string name="quiz_question_2">Nach EN 301 549 ist die Bereitstellung von Textalternativen nur für zu dekorativen Zwecken genutzte Bilder erforderlich.</string>
    
    <!-- Question 3: True/False about contrast ratio -->
    <string name="quiz_question_3">UI-Komponenten in Android-Apps müssen gemäß EN 301 549 einen Mindestkontrast von 4,5:1 zu angrenzenden Farben aufweisen.</string>
    
    <!-- Question 4: True/False about visible label matching accessible name -->
    <string name="quiz_question_4">Nach EN 301 549 ist es zulässig, wenn die sichtbare Beschriftung einer UI-Komponente nicht mit dem programmatisch bestimmten zugänglichen Namen übereinstimmt.</string>
    
    <!-- Question 5: True/False about assistive technologies modifying values -->
    <string name="quiz_question_5">Assistive Technologien müssen gemäß EN 301 549 in der Lage sein, den Wert und den Textinhalt von Benutzeroberflächenelementen zu ändern.</string>
    
    <!-- Question 6: True/False about input errors identification -->
    <string name="quiz_question_6">EN 301 549 fordert, dass Eingabefehler in mobilen Anwendungen eindeutig identifiziert und dem Nutzer beschrieben werden.</string>
    
    <!-- Question 7: True/False about text scaling -->
    <string name="quiz_question_7">Text in Android-Apps muss sich laut EN 301 549 nicht anpassen, wenn Benutzer die Systemtextgröße ändern.</string>
    
    <!-- Question 8: Multiple choice about programmatically determinable properties -->
    <string name="quiz_question_8">Welche der folgenden Eigenschaften müssen gemäß EN 301 549 von assistiven Technologien programmatisch ermittelbar sein?</string>
    <string name="quiz_question_8_option_a">A. Benutzeranmeldedaten</string>
    <string name="quiz_question_8_option_b">B. Status von UI-Elementen</string>
    <string name="quiz_question_8_option_c">C. Begrenzung von UI-Elementen</string>
    <string name="quiz_question_8_option_d">D. Rolle von UI-Elementen</string>
    
    <!-- Question 9: Multiple choice about pre-recorded synchronized media -->
    <string name="quiz_question_9">Wählen Sie alle zutreffenden Antworten: Was muss eine Android-App laut EN 301 549 für voraufgezeichnete, synchronisierte Medien bereitstellen?</string>
    <string name="quiz_question_9_option_a">A. Automatische Sprachübersetzung</string>
    <string name="quiz_question_9_option_b">B. Lautstärkeregelung</string>
    <string name="quiz_question_9_option_c">C. Audiodeskriptionen</string>
    <string name="quiz_question_9_option_d">D. Untertitel</string>
    
    <!-- Question 10: Multiple choice about accessible form fields -->
    <string name="quiz_question_10">Welche Anforderungen gelten laut EN 301 549 für barrierefreie Formulareingabefelder?</string>
    <string name="quiz_question_10_option_a">A. Nur visuelle Indikatoren</string>
    <string name="quiz_question_10_option_b">B. Eindeutige Fehleridentifikation</string>
    <string name="quiz_question_10_option_c">C. Beschriftung oder Anweisung</string>
    <string name="quiz_question_10_option_d">D. Programmatisch identifizierbarer Eingabewert</string>
    
    <!-- Question 11: Multiple choice about sole method of conveying information -->
    <string name="quiz_question_11">Was darf laut EN 301 549 NICHT als einziges Mittel zur Informationsvermittlung verwendet werden?</string>
    <string name="quiz_question_11_option_a">A. Farbe</string>
    <string name="quiz_question_11_option_b">B. Ton</string>
    <string name="quiz_question_11_option_c">C. Text</string>
    <string name="quiz_question_11_option_d">D. Vibration</string>
    
    <!-- Question 12: Multiple choice about focus order -->
    <string name="quiz_question_12">Was fordert EN 301 549 in Bezug auf die Fokusreihenfolge in einer Android-Anwendung?</string>
    <string name="quiz_question_12_option_a">A. Der Fokus darf interaktive Elemente überspringen</string>
    <string name="quiz_question_12_option_b">B. Nur sichtbare Elemente erhalten Fokus</string>
    <string name="quiz_question_12_option_c">C. Der Fokus muss einer sinnvollen Reihenfolge folgen</string>
    <string name="quiz_question_12_option_d">D. Komponenten müssen zufällig fokussiert werden</string>
    
    <!-- Question 13: Multiple choice about error prevention and feedback -->
    <string name="quiz_question_13">Welche Kriterien stehen laut EN 301 549 in direktem Zusammenhang mit Fehlervermeidung und Nutzer-Feedback bei Eingabefeldern?</string>
    <string name="quiz_question_13_option_a">A. Fehlervermeidung</string>
