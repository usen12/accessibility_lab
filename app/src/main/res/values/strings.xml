    <!-- Quiz Questions - EN 301 549 Accessibility Standards -->
    <!-- Question 1: True/False about keyboard interface -->
    <string name="quiz_question_1">In Android app accessibility testing according to EN 301 549, all functionality must be operable through a keyboard interface.</string>
    
    <!-- Question 2: True/False about text alternatives for images -->
    <string name="quiz_question_2">According to EN 301 549, providing text alternatives for images is only necessary for images used in decorative purposes.</string>
    
    <!-- Question 3: True/False about contrast ratio -->
    <string name="quiz_question_3">UI components in Android apps must have a minimum contrast ratio of 4.5:1 against adjacent colors to comply with EN 301 549.</string>
    
    <!-- Question 4: True/False about visible label matching accessible name -->
    <string name="quiz_question_4">According to EN 301 549, it is acceptable if the visible label of a UI component does not match its programmatically determined accessible name.</string>
    
    <!-- Question 5: True/False about assistive technologies modifying values -->
    <string name="quiz_question_5">Assistive technologies must be able to modify the value and text content of user interface elements according to EN 301 549.</string>
    
    <!-- Question 6: True/False about input errors identification -->
    <string name="quiz_question_6">EN 301 549 requires that input errors are clearly identified and described to the user in mobile applications.</string>
    
    <!-- Question 7: True/False about text scaling -->
    <string name="quiz_question_7">Text in Android apps does not need to scale when users adjust system text size settings according to EN 301 549.</string>
    
    <!-- Question 8: Multiple choice about programmatically determinable properties -->
    <string name="quiz_question_8">Which of the following must be programmatically determinable by assistive technologies according to EN 301 549?</string>
    <string name="quiz_question_8_option_a">A. User credentials</string>
    <string name="quiz_question_8_option_b">B. State of UI elements</string>
    <string name="quiz_question_8_option_c">C. Boundary of UI elements</string>
    <string name="quiz_question_8_option_d">D. Role of UI elements</string>
    
    <!-- Question 9: Multiple choice about pre-recorded synchronized media -->
    <string name="quiz_question_9">Select all that apply: According to EN 301 549, what should an Android app provide for pre-recorded synchronized media?</string>
    <string name="quiz_question_9_option_a">A. Automatic language translation</string>
    <string name="quiz_question_9_option_b">B. Volume control</string>
    <string name="quiz_question_9_option_c">C. Audio descriptions</string>
    <string name="quiz_question_9_option_d">D. Captions</string>
    
    <!-- Question 10: Multiple choice about accessible form fields -->
    <string name="quiz_question_10">Which of the following are required for accessible form fields according to EN 301 549?</string>
    <string name="quiz_question_10_option_a">A. Only visual indicators</string>
    <string name="quiz_question_10_option_b">B. Clear error identification</string>
    <string name="quiz_question_10_option_c">C. Label or instruction</string>
    <string name="quiz_question_10_option_d">D. Identifiable input purpose</string>
    
    <!-- Question 11: Multiple choice about sole method of conveying information -->
    <string name="quiz_question_11">Which of the following must NOT be used as the sole method of conveying information according to EN 301 549?</string>
    <string name="quiz_question_11_option_a">A. Color</string>
    <string name="quiz_question_11_option_b">B. Sound</string>
    <string name="quiz_question_11_option_c">C. Text</string>
    <string name="quiz_question_11_option_d">D. Vibration</string>
    
    <!-- Question 12: Multiple choice about focus order -->
    <string name="quiz_question_12">What does EN 301 549 require regarding focus order in an Android application?</string>
    <string name="quiz_question_12_option_a">A. Focus can skip interactive elements</string>
    <string name="quiz_question_12_option_b">B. Only visible elements receive focus</string>
    <string name="quiz_question_12_option_c">C. Focus must follow a meaningful sequence</string>
    <string name="quiz_question_12_option_d">D. Components must be focused randomly</string>
    
    <!-- Question 13: Multiple choice about error prevention and feedback -->
    <string name="quiz_question_13">Which criteria are directly related to error prevention and user feedback for input fields in EN 301 549?</string>
    <string name="quiz_question_13_option_a">A. Error Prevention</string>
    <string name="quiz_question_13_option_b">B. Error Identification</string>
    <string name="quiz_question_13_option_c">C. Table headers</string>
    <string name="quiz_question_13_option_d">D. Error Suggestion</string>
    
    <!-- Question 14: Multiple choice about assistive technology actions -->
    <string name="quiz_question_14">According to EN 301 549, which actions must an Android app allow assistive technologies to perform on UI elements?</string>
    <string name="quiz_question_14_option_a">A. Modify state</string>
    <string name="quiz_question_14_option_b">B. Change app color theme</string>
    <string name="quiz_question_14_option_c">C. Modify text value</string>
    <string name="quiz_question_14_option_d">D. Delete UI element</string>
    
    <!-- Question 15: Multiple choice about captions requirement -->
    <string name="quiz_question_15">Which of the following is a requirement for captions according to EN 301 549?</string>
    <string name="quiz_question_15_option_a">A. For images only</string>
